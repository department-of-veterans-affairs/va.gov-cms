diff --git a/autosave_form.api.php b/autosave_form.api.php
new file mode 100644
index 0000000000000000000000000000000000000000..58477c79640077ec60ae35963c6412a2820ba48f
--- /dev/null
+++ b/autosave_form.api.php
@@ -0,0 +1,35 @@
+<?php
+
+/**
+ * @file
+ * Hooks provided by the Autosave Form module.
+ */
+
+/**
+ * @addtogroup hooks
+ * @{
+ */
+
+/**
+ * Alter the autosave restore/discard modal message.
+ *
+ * This hook allows modules to customize the message displayed to users when
+ * an autosaved draft is found for the form they are editing.
+ *
+ * @param \Drupal\Core\StringTranslation\TranslatableMarkup|string $message
+ *   The message to be displayed in the restore/discard modal dialog.
+ * @param array $context
+ *   An associative array containing:
+ *   - form_state: The current form state object.
+ *   - autosave_timestamp: The timestamp of the last autosaved state.
+ *   - date: The formatted date string of the autosaved state.
+ */
+function hook_autosave_form_restore_message_alter(&$message, array $context) {
+  $message = t('A draft of this content was saved on @date. Would you like to restore it or start fresh?', [
+    '@date' => $context['date'],
+  ]);
+}
+
+/**
+ * @} End of "addtogroup hooks".
+ */
