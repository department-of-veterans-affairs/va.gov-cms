+/**
+ * @file
+ * Styles for tablefield row insertion controls.
+ */
+
+/* Wrapper that JS creates around the table for positioning context. */
+.tablefield-insert-wrapper {
+  position: relative;
+}
+
+/* Hover zone spanning the full table width at each row boundary. */
+.tablefield-insert-zone {
+  position: absolute;
+  left: 0;
+  right: 0;
+  height: 16px;
+  margin-top: -10px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  z-index: 10;
+  cursor: pointer;
+  opacity: 0;
+  transition: opacity 0.15s ease;
+}
+
+.tablefield-insert-zone:hover {
+  opacity: 1;
+}
+
+/* The line that appears on hover. */
+.tablefield-insert-zone::before {
+  content: "";
+  position: absolute;
+  left: 0;
+  right: 0;
+  top: 50%;
+  height: 2px;
+  background: #0071bc;
+  pointer-events: none;
+}
+
+/* The "+" circle button. */
+.tablefield-insert-zone .tablefield-insertrow {
+  position: relative;
+  z-index: 1;
+  width: 24px;
+  height: 24px;
+  min-width: 24px;
+  padding: 0;
+  margin: 0;
+  border: 2px solid #0071bc;
+  border-radius: 50%;
+  background: #fff;
+  color: #0071bc;
+  font-size: 18px;
+  font-weight: bold;
+  line-height: 20px;
+  cursor: pointer;
+  text-align: center;
+  font-family: Arial, sans-serif;
+}
+
+.tablefield-insert-zone .tablefield-insertrow:hover {
+  background: #0071bc;
+  color: #fff;
+}
+
+/* When showing the throbber, center it and keep button white. */
+.tablefield-insert-zone .tablefield-insertrow:has(.ajax-progress) {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  background: #fff;
+  color: #0071bc;
+}
+
+.tablefield-insert-zone .tablefield-insertrow .ajax-progress {
+  display: inline-flex;
+  padding: 0;
+  margin: 0;
+}
+
+.tablefield-insert-zone .tablefield-insertrow .ajax-progress .message {
+  display: none;
+}

