@@ -0,0 +1,81 @@
+/**
+ * @file
+ * Creates insert-row "+" buttons between table rows as hover overlays.
+ */
+
+(function (Drupal, once) {
+  'use strict';
+
+  Drupal.behaviors.tablefieldInsertRow = {
+    attach: function (context) {
+      once('tablefield-insertrow', '.form-tablefield', context).forEach(function (fieldset) {
+        var table = fieldset.querySelector('table');
+        var indexInput = fieldset.querySelector('.tablefield-insert-index');
+        var trigger = fieldset.querySelector('.tablefield-insert-trigger');
+        if (!table || !indexInput || !trigger) {
+          return;
+        }
+
+        // Wrap the table in a relative container for absolute positioning.
+        var wrapper = document.createElement('div');
+        wrapper.className = 'tablefield-insert-wrapper';
+        table.parentNode.insertBefore(wrapper, table);
+        wrapper.appendChild(table);
+
+        // Get all rows from the table body.
+        var tbody = table.querySelector('tbody') || table;
+        var rows = tbody.querySelectorAll('tr');
+        var rowCount = rows.length;
+
+        // Create a hover zone with a "+" button at each row boundary.
+        for (var i = 0; i <= rowCount; i++) {
+          (function (index) {
+            var zone = document.createElement('div');
+            zone.className = 'tablefield-insert-zone';
+
+            // Calculate vertical position.
+            var top;
+            if (rowCount === 0) {
+              top = 0;
+            }
+            else if (index === 0) {
+              top = rows[0].offsetTop;
+            }
+            else if (index >= rowCount) {
+              var lastRow = rows[rowCount - 1];
+              top = lastRow.offsetTop + lastRow.offsetHeight;
+            }
+            else {
+              var prevRow = rows[index - 1];
+              top = prevRow.offsetTop + prevRow.offsetHeight;
+            }
+            zone.style.top = top + 'px';
+
+            // Create the "+" button (purely frontend, not a form submit).
+            var btn = document.createElement('button');
+            btn.type = 'button';
+            btn.className = 'tablefield-insertrow';
+            btn.textContent = '+';
+            btn.setAttribute('aria-label', index === 0
+              ? Drupal.t('Insert row at top')
+              : (index >= rowCount
+                ? Drupal.t('Insert row at bottom')
+                : Drupal.t('Insert row after row @n', {'@n': index})));
+
+            btn.addEventListener('click', function () {
+              // Replace "+" with Drupal's standard throbber.
+              btn.textContent = '';
+              btn.innerHTML = Drupal.theme('ajaxProgressThrobber');
+              indexInput.value = index;
+              trigger.dispatchEvent(new MouseEvent('mousedown'));
+            });
+
+            zone.appendChild(btn);
+            wrapper.appendChild(zone);
+          })(i);
+        }
+      });
+    }
+  };
+
+})(Drupal, once);
