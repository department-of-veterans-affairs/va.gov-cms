+
+  /**
+   * Retrieve revision-aware usage data for detailed usage output.
+   *
+   * @param string $entityType
+   *   Entity type.
+   * @param int $entityId
+   *   Entity ID.
+   *
+   * @return array
+   *   Usage rows keyed by source entity type and source entity ID.
+   */
+  protected function getDetailedUsage($entityType, $entityId) {
+    $entity = $this->entityTypeManager->getStorage($entityType)->load($entityId);
+    if (!$entity) {
+      return [];
+    }
+
+    $allUsages = $this->entityUsage->listSources($entity);
+    $detailedUsage = [];
+
+    foreach ($allUsages as $sourceType => $ids) {
+      foreach ($ids as $sourceId => $records) {
+        $sourceEntity = $this->entityTypeManager->getStorage($sourceType)->load($sourceId);
+        if (!$sourceEntity) {
+          continue;
+        }
+
+        $usage = [
+          'source_entity' => $sourceEntity,
+          'has_default_revision' => TRUE,
+          'has_old_revision' => FALSE,
+        ];
+
+        if ($sourceEntity instanceof RevisionableInterface) {
+          $usage['has_default_revision'] = FALSE;
+          $defaultRevisionId = (int) $sourceEntity->getRevisionId();
+
+          foreach ($records as $record) {
+            if (!array_key_exists('source_vid', $record) || $record['source_vid'] === NULL) {
+              $usage['has_default_revision'] = TRUE;
+              continue;
+            }
+
+            $sourceVid = (int) $record['source_vid'];
+            if ($sourceVid === $defaultRevisionId) {
+              $usage['has_default_revision'] = TRUE;
+            }
+            elseif ($sourceVid < $defaultRevisionId) {
+              $usage['has_old_revision'] = TRUE;
+            }
+          }
+        }
+
+        $detailedUsage[$sourceType][$sourceId] = $usage;
+      }
+    }
+
+    return $detailedUsage;
+  }
+
+  /**
+   * Determine if usage exists only on previous revisions.
+   *
+   * @param array $usage
+   *   Usage metadata for a source entity.
+   *
+   * @return bool
+   *   TRUE when usage is from previous revisions only.
+   */
+  protected function isPreviousRevisionUsage(array $usage): bool {
+    return !empty($usage['has_old_revision']) && empty($usage['has_default_revision']);
+  }
