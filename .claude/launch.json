{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "DDEV",
      "runtimeExecutable": "ddev",
      "runtimeArgs": ["start"],
      "port": 443
    },
    {
      "name": "JS Watch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "watch"],
      "port": 0
    },
    {
      "name": "Theme Dev (vagovclaro)",
      "runtimeExecutable": "composer",
      "runtimeArgs": ["va:theme:watch"],
      "port": 0
    },
    {
      "name": "Next.js",
      "runtimeExecutable": "composer",
      "runtimeArgs": ["va:next:start"],
      "port": 3000
    }
  ]
}
